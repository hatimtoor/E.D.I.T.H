# ─── LLM providers (set at least one) ───────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
EDITH_MODEL=anthropic:claude-opus-4-8

# ─── Stealth browser ────────────────────────────────────────────────
# Residential / rotating proxy — the single biggest fix for Linux-server blocking.
# Format: http://user:pass@host:port
EDITH_PROXY=
# Comma-separated proxy pool for rotation (overrides EDITH_PROXY)
EDITH_PROXY_POOL=
# Optional CAPTCHA solver (2captcha / capsolver) key
EDITH_CAPTCHA_KEY=

# ─── runtime ────────────────────────────────────────────────────────
EDITH_HOME=.edith
EDITH_LOG_LEVEL=INFO
EDITH_RUFLO_ENABLED=true
