# ─── LLM providers (set at least one) ───────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# default model (provider:model). Anthropic recommended for the agent loop.
EDITH_MODEL=anthropic:claude-opus-4-8

# ─── Stealth browser ────────────────────────────────────────────────
# Residential / rotating proxy. The single biggest fix for Linux-server blocking
# is NOT using a datacenter IP. Format: http://user:pass@host:port
EDITH_PROXY=
# Comma-separated proxy pool for rotation (optional, overrides EDITH_PROXY)
EDITH_PROXY_POOL=
# Optional CAPTCHA-solver fallback (2captcha / capsolver) API key
EDITH_CAPTCHA_KEY=

# ─── ruflo MCP orchestration ────────────────────────────────────────
EDITH_RUFLO_ENABLED=true

# ─── runtime ────────────────────────────────────────────────────────
EDITH_HOME=.edith
EDITH_LOG_LEVEL=INFO
